NODE_ENV=development
BACKEND_URL=http://127.0.0.1:5000
BACKEND_BASE_URL=http://127.0.0.1:5000
WORKER_TOKEN=
BACKEND_API_KEY=
WORKSPACE_ID=demo-workspace
WORKER_ID=
NODE_NAME=worker-laptop-01
WORKER_NAME=worker-laptop-01
