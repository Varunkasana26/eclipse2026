{
  "simpleWorkspaceJob": {
    "image": "node:20-alpine",
    "command": "node -e \"console.log('CampusCloud simple job')\"",
    "workspace_id": "demo-workspace",
    "requires_gpu": false,
    "chunk_count": 1
  },
  "gpuLaneJob": {
    "image": "pytorch/pytorch:2.3.0-cuda12.1-cudnn8-runtime",
    "command": "python -c \"print('gpu lane job')\"",
    "workspace_id": "demo-workspace",
    "requires_gpu": true,
    "lane_required": "mid",
    "estimated_gpu_percent": 40,
    "chunk_count": 1
  },
  "chunkedGpuJob": {
    "image": "pytorch/pytorch:2.3.0-cuda12.1-cudnn8-runtime",
    "command": "python -c \"print('chunked gpu job')\"",
    "workspace_id": "demo-workspace",
    "requires_gpu": true,
    "lane_required": "high",
    "estimated_gpu_percent": 30,
    "chunk_count": 3,
    "env": {
      "BATCH_ID": "demo-01"
    }
  }
}
