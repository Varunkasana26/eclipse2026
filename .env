APP_APP_NAME=gpu-execution-backend
APP_DEBUG=false
APP_DOCKER_NETWORK_DISABLED=true
APP_EXECUTION_TIMEOUT_SECONDS=5
APP_MEMORY_LIMIT=1g
APP_NANO_CPUS=1000000000
APP_PIDS_LIMIT=64
APP_PYTHON_IMAGE_NAME=hackathon-python-runtime:latest
APP_PYTORCH_IMAGE_NAME=hackathon-pytorch-runtime:latest
APP_BACKEND_HOST=0.0.0.0
APP_BACKEND_PORT=8000
APP_DOCKER_SOCKET=npipe:////./pipe/docker_engine
